{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "tests/**/*",
    "examples/**/*",
    "**/*.test.ts",
    "**/*.bench.ts",
    "dist/**/*",
    "node_modules"
  ]
}
